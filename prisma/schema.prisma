generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["driverAdapters"]
}

datasource db {
  provider = "postgresql"
}

// ─────────────────────────────────────────────
// ENUMS
// ─────────────────────────────────────────────

enum TipoUsuario {
  admin
  gestor
  operacao
  solicitante
  editor
  videomaker
  social
  gestor_eventos
  designer
  analista_crm
  gestor_trafego
  auxiliar_admin
}

enum StatusUsuario {
  ativo
  inativo
}

enum StatusVideomaker {
  ativo
  inativo
  preferencial
  pendente
}

enum Prioridade {
  normal
  alta
  urgente
}

enum AreaDemanda {
  audiovisual
  design
}

enum Departamento {
  growth
  eventos
  institucional
  rh
  audiovisual
  outros
}

enum StatusVisivel {
  entrada
  producao
  edicao
  aprovacao
  para_postar
  finalizado
}

enum StatusInterno {
  pedido_criado
  aguardando_aprovacao_interna
  aguardando_triagem
  urgencia_pendente_aprovacao
  urgencia_aprovada
  planejamento
  videomaker_notificado
  videomaker_aceitou
  videomaker_recusou
  captacao_agendada
  captacao_realizada
  brutos_enviados
  editor_atribuido
  fila_edicao
  editando
  edicao_finalizada
  revisao_pendente
  aprovado
  ajuste_solicitado
  impedimento
  postagem_pendente
  postado
  entregue_cliente
  contagem_15_dias_iniciada
  lembrete_15_dias_enviado
  expirado
  encerrado
}

enum OrigemHistorico {
  manual
  automacao
  ia
  whatsapp
  kanban
}

enum TipoArquivo {
  bruto
  final
  nota_fiscal
  referencia
  postagem
  cliente
  documento
}

enum DirecaoWhatsapp {
  entrada
  saida
}

enum StatusAlerta {
  ativo
  resolvido
  ignorado
}

enum SeveridadeAlerta {
  info
  aviso
  critico
}

enum StatusIdeia {
  nova
  em_analise
  aprovada
  em_producao
  realizada
  descartada
}

enum OrigemIdeia {
  whatsapp
  manual
  instagram
  tiktok
  youtube
  outro
}

// ─────────────────────────────────────────────
// MODELS
// ─────────────────────────────────────────────

model Usuario {
  id        String        @id @default(cuid())
  nome      String
  email     String?       @unique
  telefone  String?
  tipo      TipoUsuario   @default(solicitante)
  status    StatusUsuario @default(ativo)
  senhaHash String
  avatarUrl String?
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt
  superAdmin Boolean      @default(false)  // gestão global de organizações (SaaS)

  organizacoes    UsuarioOrganizacao[]
  demandasCriadas Demanda[]         @relation("Solicitante")
  demandasGeridas Demanda[]         @relation("Gestor")
  demandasResponsavel Demanda[]     @relation("Responsavel")
  historicos      HistoricoStatus[]
  comentarios     Comentario[]
  sessions        Session[]
  eventos         Evento[]
  permissoes      PermissaoUsuario?
  videomakerRef   Videomaker?       // link para videomaker externo (quando tipo=videomaker)
  editorRef       Editor?           // link para editor/videomaker interno (quando tipo=editor)
  designerRef     Designer?         // link para designer (quando tipo=designer)
  ideias          IdeiaVideo[]
  coberturasCriadas EventoCobertura[] @relation("CoberturasCreadas")
  coberturaEquipe EventoCoberturaEquipe[]
  eventosResponsavel  EventoGestao[]          @relation("EventoGestaoResponsavel")
  eventosCriados      EventoGestao[]          @relation("EventoGestaoCriador")
  eventoChecklistResp EventoGestaoChecklist[]
  eventoDocumentoResp EventoGestaoDocumento[]

  @@map("usuarios")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         Usuario  @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model Videomaker {
  id               String           @id @default(cuid())
  nome             String
  cidade           String?
  estado           String?
  telefone         String?
  email            String?
  cpfCnpj          String?
  razaoSocial      String?
  nomeFantasia     String?
  representante    String?
  endereco         String?
  chavePix         String?
  redesSociais     String[]
  valorDiaria      Float?
  dadosBancarios   String?
  status           StatusVideomaker @default(ativo)
  avaliacao        Float?           @default(5.0)
  observacoes      String?
  areasAtuacao     String[]
  habilidades      String[]         // tags: "Edição", "3D", "Drone" etc.
  equipamentos     String[]         // câmeras, lentes, drones, iluminação etc.
  portfolio        String?
  emListaNegra     Boolean          @default(false)
  listaNegraMotivo String?
  podeEditar       Boolean          @default(false)
  tipoContrato     String           @default("externo")  // "externo" (freelance) | "interno" (fulltime)
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt

  usuarioId  String?    @unique  // link para Usuario (portal login)
  usuario    Usuario?   @relation(fields: [usuarioId], references: [id])

  demandas       Demanda[]
  eventos        Evento[]
  custos         CustoVideomaker[]
  avaliacoes     AvaliacaoVideomaker[]
  convites         ConviteVideomaker[]
  notasFiscais     NotaFiscalUpload[]
  coberturaEquipe  EventoCoberturaEquipe[]

  @@map("videomakers")
}

model Editor {
  organizacaoId String?
  id            String        @id @default(cuid())
  nome          String
  telefone      String?
  whatsapp      String?       // número WhatsApp (pode ser igual ao telefone)
  email         String?
  avatarUrl     String?       // foto de perfil
  especialidade String[]
  habilidades   String[]      // tags abertas de habilidades
  cargaLimite   Int           @default(5)
  status        StatusUsuario @default(ativo)
  avaliacao        Float?        @default(5.0)
  cidade           String?
  estado           String?
  cpfCnpj          String?
  razaoSocial      String?
  nomeFantasia     String?
  representante    String?
  endereco         String?
  chavePix         String?
  redesSociais     String[]
  salario          Float?           // ONLY visible to admin/gestor
  dadosBancarios   String?
  observacoes      String?
  areasAtuacao     String[]
  equipamentos     String[]
  portfolio        String?
  emListaNegra     Boolean          @default(false)
  listaNegraMotivo String?
  fazCaptacao      Boolean          @default(false)
  tipoContrato     String           @default("interno")  // "interno" (fulltime) | "externo" (freelance)
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt

  usuarioId  String?    @unique  // link para Usuario (portal login)
  usuario    Usuario?   @relation(fields: [usuarioId], references: [id])

  demandas   Demanda[]
  avaliacoes AvaliacaoEditor[]
  eventos    Evento[]
  coberturaEquipe  EventoCoberturaEquipe[]

  @@map("editores")
}

model Designer {
  organizacaoId String?
  id               String        @id @default(cuid())
  nome             String
  cidade           String?
  estado           String?
  telefone         String?
  whatsapp         String?
  email            String?
  avatarUrl        String?
  cpfCnpj          String?
  razaoSocial      String?
  nomeFantasia     String?
  representante    String?
  endereco         String?
  chavePix         String?
  redesSociais     String[]
  valorDiaria      Float?
  salario          Float?
  dadosBancarios   String?
  status           StatusUsuario @default(ativo)
  avaliacao        Float?        @default(5.0)
  observacoes      String?
  especialidade    String[]      // "Social", "Impresso", "Motion", "3D"
  habilidades      String[]
  equipamentos     String[]
  portfolio        String?
  emListaNegra     Boolean       @default(false)
  listaNegraMotivo String?
  tipoContrato     String        @default("externo")  // "interno" | "externo"
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt

  usuarioId  String?    @unique  // link para Usuario (portal login)
  usuario    Usuario?   @relation(fields: [usuarioId], references: [id])

  demandas   Demanda[]

  @@map("designers")
}

model Demanda {
  organizacaoId String?
  id             String        @id @default(cuid())
  codigo         String        @unique
  titulo         String
  descricao      String
  departamento   Departamento
  area           AreaDemanda   @default(audiovisual)  // audiovisual | design
  tipoVideo      String
  cidade         String
  prioridade     Prioridade    @default(normal)
  motivoUrgencia String?
  statusVisivel  StatusVisivel @default(entrada)
  statusInterno  StatusInterno @default(pedido_criado)
  pesoDemanda    Float         @default(1)
  riscoAtraso    Boolean       @default(false)

  classificacao     String?    // "b2c" | "b2b" — classification of the video

  // Dados extras por departamento
  campanha          String?
  objetivo          String?
  plataforma        String?
  dataEvento        DateTime?
  localEvento       String?
  cobertura         Boolean?
  publico           String?
  mensagemPrincipal String?

  // Links operacionais
  linkBrutos      String?
  linkFinal       String?
  linkPostagem    String?
  postagemTipo    String?   // "feed" | "story" | "reels" | "youtube" | "outro"
  linkCliente     String?
  localGravacao   String?
  referencia      String?

  // Impedimento
  motivoImpedimento String?

  // Solicitante externo (capturado via WhatsApp para follow-up)
  telefoneSolicitante String?
  nomeSolicitante     String?    // Nome de quem realmente pediu (pode ser externo)

  // Cliente final (cobertura/entrega de equipamento)
  clienteFinalNome     String?
  clienteFinalTelefone String?
  clienteFinalEmail    String?

  // Nota fiscal
  notaFiscalUrl  String?
  notaFiscalNome String?

  posicaoKanban     Int?               // posição dentro da coluna (para reordenação)
  trelloCardId      String?  @unique  // Trello card ID to prevent re-import

  // Pastas Google Drive (cobertura)
  linkFolderBrutos     String?    // pasta [Material Bruto] no Drive
  linkFolderFinal      String?    // pasta [Material Pronto] no Drive

  // Thumbnail gerada no cliente e salva no Supabase
  thumbnailUrl         String?    // JPEG em /storage/v1/object/public/uploads/thumbnails/...

  // Controle de limpeza pós-finalização
  finalizadaEm         DateTime?  // setado automaticamente quando statusVisivel = "finalizado"
  limpezaNotificadaEm  DateTime?  // quando foi enviado aviso de 20 dias
  limpezaExecutadaEm   DateTime?  // quando foi removida a referência de brutos

  // Relações de usuários (FKs)
  solicitanteId String
  gestorId      String?
  videomakerId  String?
  editorId      String?
  socialId      String?
  designerId    String?   // profissional de design (quando area=design)
  responsavelId String?   // responsável/executor interno (Growth) — Usuario da org
  // Segmentação genérica multiempresa (linha de conteúdo / projeto / marca / cliente /
  // unidade / produto). NUNCA hardcoded por empresa. Usado p/ filtrar e, no futuro, permissões.
  // `linhaProjeto` (texto) mantido p/ compat/backfill; a referência principal é linhaProjetoId.
  linhaProjeto   String?
  linhaProjetoId String?

  // Datas
  dataLimite         DateTime?
  dataCaptacao       DateTime?
  dataPostagem       DateTime?
  dataEntregaCliente DateTime?
  dataExpiracao      DateTime?
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  // Relações
  solicitante        Usuario            @relation("Solicitante", fields: [solicitanteId], references: [id])
  gestor             Usuario?           @relation("Gestor", fields: [gestorId], references: [id])
  videomaker         Videomaker?        @relation(fields: [videomakerId], references: [id])
  editor             Editor?            @relation(fields: [editorId], references: [id])
  designer           Designer?          @relation(fields: [designerId], references: [id])
  responsavel        Usuario?           @relation("Responsavel", fields: [responsavelId], references: [id])
  linhaProjetoRef    LinhaProjeto?      @relation(fields: [linhaProjetoId], references: [id])
  arquivos           Arquivo[]
  historicos         HistoricoStatus[]
  comentarios        Comentario[]
  alertas            AlertaIA[]
  aprovacoesVideo    AprovacaoVideo[]
  mensagensWhatsapp  MensagemWhatsapp[]
  logsAutomacao      LogAutomacao[]
  eventos            Evento[]
  custos             CustoVideomaker[]
  produtos           DemandaProduto[]
  checklistItens     ChecklistItem[]
  convites           ConviteVideomaker[]
  notasFiscais       NotaFiscalUpload[]
  ideia              IdeiaVideo?
  emailsEntrada      EmailEntrada[]

  // Evento de cobertura vinculado (quando convertida)
  coberturaId        String?
  coberturaEvento    EventoCobertura?   @relation(fields: [coberturaId], references: [id])

  // Evento mestre (Nuflow Eventos) que gerou esta peça audiovisual
  eventoGestaoId     String?
  eventoGestao       EventoGestao?      @relation(fields: [eventoGestaoId], references: [id])

  @@map("demandas")
}

// ── Checklist System (estilo Trello) ──────────────────────────────────────────

model ChecklistTemplate {
  id        String                  @id @default(cuid())
  nome      String                  // "Entrega Equipamento - VM Externo"
  tipoVideo String?                 // match automático ao criar demanda
  papel     String?                 // "videomaker_externo" | "editor" | "social" | "geral"
  ativo     Boolean                 @default(true)
  itens     ChecklistTemplateItem[]
  createdAt DateTime                @default(now())
  updatedAt DateTime                @updatedAt

  @@map("checklist_templates")
}

model ChecklistTemplateItem {
  id         String            @id @default(cuid())
  templateId String
  texto      String
  ordem      Int               @default(0)
  template   ChecklistTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)

  @@map("checklist_template_itens")
}

model ChecklistItem {
  id           String    @id @default(cuid())
  demandaId    String
  texto        String
  concluido    Boolean   @default(false)
  concluidoEm  DateTime?
  concluidoPor String?
  ordem        Int       @default(0)
  grupo        String?   // "videomaker_externo", "editor", "social", "geral"
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  demanda Demanda @relation(fields: [demandaId], references: [id], onDelete: Cascade)

  @@map("checklist_itens")
}

model Arquivo {
  id           String      @id @default(cuid())
  demandaId    String
  tipoArquivo  TipoArquivo
  nomeArquivo  String
  url          String
  tamanho      Int?
  origem       String?
  sequencia    Int?        // ordem na demanda: 1, 2, 3... → Drive: 001, 002, 003
  thumbnailUrl String?     // JPEG thumbnail no Supabase (gerado no cliente)
  transcodeStatus String?  // null | "processing" | "done" | "skipped" | "failed" (HEVC→MP4)
  originalUrl  String?     // backup da URL original (HEVC) antes de trocar para MP4
  createdAt    DateTime    @default(now())

  demanda Demanda @relation(fields: [demandaId], references: [id], onDelete: Cascade)

  @@map("arquivos")
}

model HistoricoStatus {
  id             String          @id @default(cuid())
  demandaId      String
  statusAnterior String?
  statusNovo     String
  usuarioId      String?
  origem         OrigemHistorico @default(manual)
  observacao     String?
  createdAt      DateTime        @default(now())

  demanda Demanda  @relation(fields: [demandaId], references: [id], onDelete: Cascade)
  usuario Usuario? @relation(fields: [usuarioId], references: [id])

  @@map("historico_status")
}

model Comentario {
  id         String   @id @default(cuid())
  demandaId  String
  usuarioId  String
  comentario String
  origem     String   @default("manual")
  createdAt  DateTime @default(now())

  demanda Demanda @relation(fields: [demandaId], references: [id], onDelete: Cascade)
  usuario Usuario @relation(fields: [usuarioId], references: [id])

  @@map("comentarios")
}

model AlertaIA {
  organizacaoId String?
  id           String           @id @default(cuid())
  demandaId    String?
  usuarioId    String?
  tipoAlerta   String
  mensagem     String
  severidade   SeveridadeAlerta @default(aviso)
  status       StatusAlerta     @default(ativo)
  lida         Boolean          @default(false)
  acaoSugerida String?
  createdAt    DateTime         @default(now())
  resolvedAt   DateTime?
  snoozeAte    DateTime?        // TDAH: silenciar temporariamente

  demanda Demanda? @relation(fields: [demandaId], references: [id], onDelete: Cascade)

  @@map("alertas_ia")
}

model AprovacaoVideo {
  id           String   @id @default(cuid())
  demandaId    String
  token        String   @unique @default(cuid())
  nomeVideo    String?
  urlVideo     String
  status       String   @default("pendente")
  aprovadoPor  String?
  comentario   String?
  expiresAt    DateTime?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  demanda Demanda @relation(fields: [demandaId], references: [id], onDelete: Cascade)

  @@map("aprovacoes_video")
}

model ConfigWhatsapp {
  id                String    @id @default(cuid())
  organizacaoId     String?   @unique  // 1 WhatsApp por empresa
  instanceUrl       String             // (Bloco 8: virá do env da Evolution gerenciada)
  apiKey            String             // (Bloco 8: virá do env da Evolution gerenciada)
  instanceId        String    @unique
  instanceName      String?            // ex: nuflow_contourline
  telefoneConectado String?
  pushName          String?
  connectedAt       DateTime?
  lastStatus        String?
  ativo             Boolean   @default(false)
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  @@map("config_whatsapp")
}

model MensagemWhatsapp {
  organizacaoId String?
  id           String          @id @default(cuid())
  demandaId    String?
  telefone     String
  tipoMensagem String          // "text" | "image" | "video" | "audio" | "document"
  conteudo     String
  mediaUrl     String?         // URL do arquivo no Supabase Storage (se mídia)
  mediaType    String?         // MIME type (ex: "image/jpeg", "audio/ogg")
  direcao      DirecaoWhatsapp @default(saida)
  status       String          @default("enviado")
  createdAt    DateTime        @default(now())

  demanda Demanda? @relation(fields: [demandaId], references: [id])

  @@map("mensagens_whatsapp")
}

model ContatoWhatsApp {
  organizacaoId String?
  id        String   @id @default(cuid())
  telefone  String
  nome      String
  tipo      String   @default("externo")  // externo | videomaker | editor | usuario
  referenciaId String?                    // ID do videomaker/editor/usuario se vinculado
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([organizacaoId, telefone])
  @@map("contatos_whatsapp")
}

// Cache de resolução @lid → JID real (evita atribuição errada de mensagens)
model MapaLidWhatsApp {
  organizacaoId String?
  id        String   @id @default(cuid())
  lidJid    String                        // ex: "123456789@lid"
  realJid   String                        // ex: "5531991900114@s.whatsapp.net"
  telefone  String                        // ex: "5531991900114"
  pushName  String?                       // nome de exibição no WhatsApp
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([organizacaoId, lidJid])
  @@index([telefone])
  @@map("mapa_lid_whatsapp")
}

model LogAutomacao {
  id         String   @id @default(cuid())
  demandaId  String?
  automacao  String
  inputJson  Json?
  outputJson Json?
  status     String   @default("sucesso")
  createdAt  DateTime @default(now())

  demanda Demanda? @relation(fields: [demandaId], references: [id])

  @@map("logs_automacao")
}

// ─────────────────────────────────────────────
// AGENDA
// ─────────────────────────────────────────────

enum TipoEvento {
  captacao
  edicao
  reuniao
  freelance
  pessoal
  empresa
  prazo
  outro
}

enum ContextoEvento {
  contourline  // prioridade máxima — empresa principal
  freelance    // serviços externos
  pessoal      // agenda particular do admin
  sistema      // gerado automaticamente por demanda
}

enum StatusEvento {
  agendado
  confirmado
  em_andamento
  concluido
  cancelado
}

model Evento {
  organizacaoId String?
  id           String         @id @default(cuid())
  titulo       String
  descricao    String?
  inicio       DateTime
  fim          DateTime
  diaTodo      Boolean        @default(false)
  tipo         TipoEvento     @default(outro)
  contexto     ContextoEvento @default(sistema)
  status       StatusEvento   @default(agendado)
  cor          String?        // hex, ex: #ef4444
  local        String?
  privado      Boolean        @default(false)

  // Relações opcionais
  demandaId    String?
  usuarioId    String?        // admin/gestor
  videomakerId String?        // agenda do videomaker externo
  editorId     String?        // agenda do videomaker interno (editor)

  lembreteMinutos Int            @default(60)    // TDAH: minutos antes do evento para enviar WA
  lembreteEnviado Boolean        @default(false) // TDAH: lembrete já enviado?

  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt

  demanda    Demanda?    @relation(fields: [demandaId], references: [id], onDelete: Cascade)
  usuario    Usuario?    @relation(fields: [usuarioId], references: [id])
  videomaker Videomaker? @relation(fields: [videomakerId], references: [id])
  editor     Editor?     @relation(fields: [editorId], references: [id])

  @@map("eventos")
}

// ─────────────────────────────────────────────
// CUSTOS
// ─────────────────────────────────────────────

enum TipoCusto {
  diaria
  mensalidade
  projeto
  bonus
  despesa
  equipamento
}

enum StatusPagamento {
  pendente_nf          // aguardando videomaker enviar nota fiscal
  nf_enviada           // NF recebida, aguardando aprovação interna
  aguardando_pagamento // aprovado → e-mail enviado ao financeiro
  pago                 // confirmado pago
  contestado           // em disputa
}

model CustoVideomaker {
  organizacaoId String?
  id                String          @id @default(cuid())
  videomakerId      String
  demandaId         String?
  tipo              TipoCusto       @default(diaria)
  valor             Float
  descricao         String?
  dataReferencia    DateTime
  pago              Boolean         @default(false)
  dataPagamento     DateTime?
  comprovante       String?
  notaFiscalUrl     String?         // URL da NF enviada pelo videomaker
  statusPagamento   StatusPagamento @default(pendente_nf)
  emailFinanceiroAt DateTime?       // quando o e-mail foi enviado ao financeiro
  dataVencimento    DateTime?       // TDAH: prazo para cobrança automática
  ultimaCobrancaEm  DateTime?       // TDAH: última vez que enviou cobrança WA
  qtdCobranças      Int             @default(0) // TDAH: quantas cobranças já foram enviadas
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt

  videomaker Videomaker @relation(fields: [videomakerId], references: [id])
  demanda    Demanda?   @relation(fields: [demandaId], references: [id])

  @@map("custos_videomaker")
}

// ─────────────────────────────────────────────
// RELATÓRIOS IA
// ─────────────────────────────────────────────

enum TipoRelatorio {
  produtividade_time
  analise_custos
  otimizacao_contratacao
  performance_videomaker
  semanal
  mensal
  realtime
  banco_ideias
}

model RelatorioIA {
  organizacaoId String?
  id         String        @id @default(cuid())
  tipo       TipoRelatorio
  periodo    String        // ex: "2025-W01", "2025-03", "realtime"
  conteudo   Json          // resposta estruturada da IA
  tokens     Int?          // tokens consumidos
  modelo     String        @default("claude-haiku-4-5")
  createdAt  DateTime      @default(now())

  @@map("relatorios_ia")
}

// ─────────────────────────────────────────────
// E-MAIL / FINANCEIRO
// ─────────────────────────────────────────────

model ConfigEmail {
  organizacaoId String?
  id               String   @id @default(cuid())
  apiKey           String   @default("") // Resend API Key
  senderEmail      String   @default("onboarding@resend.dev")
  senderNome       String   @default("VideoOps")
  emailsFinanceiro String[] // destinatários financeiro
  ativo            Boolean  @default(false)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@map("config_email")
}

// Caixa de entrada conectada diretamente ao provedor de e-mail.
// A mensagem e salva antes do parsing para permitir retomada e auditoria.
model ConfigEmailEntrada {
  id                           String   @id @default(cuid())
  organizacaoId                String   @unique
  provedor                     String   @default("microsoft365")
  emailCaixa                   String?
  tenantId                     String?
  refreshTokenCriptografado    String?  @db.Text
  remetenteFiltro              String?
  assuntoFiltro                String?
  criarDemandaAutomaticamente Boolean  @default(false)
  solicitantePadraoId          String?
  ativo                        Boolean  @default(false)
  conectadoEm                  DateTime?
  ultimaSincronizacaoEm        DateTime?
  ultimoErro                   String?  @db.Text
  createdAt                    DateTime @default(now())
  updatedAt                    DateTime @updatedAt

  organizacao Organizacao  @relation(fields: [organizacaoId], references: [id], onDelete: Cascade)
  emails      EmailEntrada[]

  @@map("config_email_entrada")
}

model EmailEntrada {
  id                 String   @id @default(cuid())
  organizacaoId      String
  configId           String
  mensagemProvedorId String
  internetMessageId  String?
  conversationId     String?
  remetenteNome      String?
  remetenteEmail     String
  destinatarios      String[]
  assunto            String
  recebidoEm         DateTime
  corpoTexto         String   @db.Text
  corpoHtml          String?  @db.Text
  possuiAnexos       Boolean  @default(false)
  anexos              Json?
  dadosExtraidos      Json?
  status              String   @default("pendente") // pendente | pronto | processando | criado | revisao | ignorado | erro
  erro                String?  @db.Text
  tentativas          Int      @default(0)
  demandaId           String?
  processadoEm        DateTime?
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  organizacao Organizacao       @relation(fields: [organizacaoId], references: [id], onDelete: Cascade)
  config      ConfigEmailEntrada @relation(fields: [configId], references: [id], onDelete: Cascade)
  demanda     Demanda?           @relation(fields: [demandaId], references: [id], onDelete: SetNull)

  @@unique([organizacaoId, mensagemProvedorId])
  @@index([organizacaoId, status, recebidoEm])
  @@index([demandaId])
  @@map("emails_entrada")
}

// ─────────────────────────────────────────────
// AVALIAÇÕES DE VIDEOMAKER
// ─────────────────────────────────────────────

model AvaliacaoVideomaker {
  id           String     @id @default(cuid())
  videomakerId String
  nota         Int        // 1-5
  comentario   String?
  avaliadorId  String?    // null se via QR (avaliação pública)
  demandaId    String?
  origem       String     @default("interno") // "interno" | "qr_publico"
  createdAt    DateTime   @default(now())

  videomaker Videomaker @relation(fields: [videomakerId], references: [id], onDelete: Cascade)

  @@map("avaliacoes_videomaker")
}

// ─────────────────────────────────────────────
// AVALIAÇÕES DE EDITOR (Videomaker Int)
// ─────────────────────────────────────────────

model AvaliacaoEditor {
  id          String   @id @default(cuid())
  editorId    String
  nota        Int      // 1-5
  comentario  String?
  atendeuDemandas  Boolean?   // checklist: atendeu as demandas?
  foiAtencioso     Boolean?   // foi atencioso?
  contratariaNovamente Boolean? // contrataria novamente?
  avaliadorId String?          // null se via QR público
  demandaId   String?
  origem      String   @default("interno") // "interno" | "qr_publico"
  createdAt   DateTime @default(now())

  editor Editor @relation(fields: [editorId], references: [id], onDelete: Cascade)

  @@map("avaliacoes_editor")
}

// ─────────────────────────────────────────────
// PARÂMETROS DINÂMICOS (configurações editáveis)
// ─────────────────────────────────────────────

model ConfigParametro {
  organizacaoId String?
  id        String   @id @default(cuid())
  grupo     String   // "departamentos" | "tipos_video" | "habilidades" | "areas_atuacao"
  valor     String   // valor interno (ex: "growth")
  label     String   // label de exibição (ex: "Growth")
  ordem     Int      @default(0)
  ativo     Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([grupo, valor])
  @@map("config_parametros")
}

// ─────────────────────────────────────────────
// IA — CHAT E EXECUÇÃO DE AGENTES
// ─────────────────────────────────────────────

model ChatIAMensagem {
  id        String   @id @default(cuid())
  sessionId String   // identificador da sessão de chat (gerado no frontend)
  role      String   // "user" | "assistant"
  conteudo  String   @db.Text
  tokens    Int?
  createdAt DateTime @default(now())

  @@index([sessionId])
  @@map("chat_ia_mensagens")
}

model AgenteExecucao {
  id             String    @id @default(cuid())
  agente         String    // "triagem" | "monitor" | "gerar_alertas" | "custos" | "whatsapp"
  status         String    @default("executando") // "executando" | "concluido" | "erro"
  resultado      Json?
  tokens         Int?
  alertasGerados Int       @default(0)
  ferramentas    String[]  // ferramentas usadas
  erro           String?
  criadoPor      String?   // userId que acionou
  finishedAt     DateTime?
  createdAt      DateTime  @default(now())

  @@map("agente_execucoes")
}

// ─────────────────────────────────────────────
// RESET DE SENHA
// ─────────────────────────────────────────────

model PasswordResetToken {
  id        String    @id @default(cuid())
  email     String
  token     String    @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  @@map("password_reset_tokens")
}

// ─────────────────────────────────────────────
// PRODUTOS & CONTEÚDO
// ─────────────────────────────────────────────

model Fabricante {
  id        String    @id @default(cuid())
  nome      String    @unique
  ativo     Boolean   @default(true)
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  produtos  Produto[]

  @@map("fabricantes")
}

model Produto {
  organizacaoId String?
  id              String      @id @default(cuid())
  nome            String
  descricao       String?
  categoria       String?     // legacy — use fabricanteId
  fabricanteId    String?
  peso            Float       @default(1.0)    // 1-10 priority weight
  ativo           Boolean     @default(true)
  alertaDias      Int         @default(30)     // alert if no content in X days
  ultimoConteudo  DateTime?                  // denormalized: last content date
  totalConteudos  Int       @default(0)      // denormalized: total content count
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  fabricante      Fabricante?      @relation(fields: [fabricanteId], references: [id])
  demandas    DemandaProduto[]
  ideias      IdeiaVideo[]
  coberturas  EventoCobertura[]

  @@map("produtos")
}

model DemandaProduto {
  id         String   @id @default(cuid())
  demandaId  String
  produtoId  String
  createdAt  DateTime @default(now())

  demanda    Demanda  @relation(fields: [demandaId], references: [id], onDelete: Cascade)
  produto    Produto  @relation(fields: [produtoId], references: [id], onDelete: Cascade)

  @@unique([demandaId, produtoId])
  @@map("demanda_produto")
}

// ─────────────────────────────────────────────
// BANCO DE IDEIAS
// ─────────────────────────────────────────────

model IdeiaVideo {
  organizacaoId String?
  id              String       @id @default(cuid())
  titulo          String
  descricao       String?      @db.Text
  linkReferencia  String?
  mediaUrl        String?
  mediaType       String?
  origem          OrigemIdeia  @default(manual)
  plataforma      String?      // auto-detected: instagram, tiktok, youtube
  status          StatusIdeia  @default(nova)
  classificacao   String?      // b2c, b2b

  // IA Analysis
  scoreIA            Float?    // 0-100
  analiseIA          String?   @db.Text
  sugestaoTipo       String?
  sugestaoPrioridade String?
  analisadoEm        DateTime?

  // Quem enviou
  enviadoPor     String?
  telefoneOrigem String?
  usuarioId      String?

  // Produto
  produtoId String?

  // Conversão em demanda
  demandaId    String?   @unique
  convertidoEm DateTime?

  tags      String[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  usuario Usuario? @relation(fields: [usuarioId], references: [id])
  produto Produto? @relation(fields: [produtoId], references: [id])
  demanda Demanda? @relation(fields: [demandaId], references: [id])

  @@map("ideias_video")
}

// ─────────────────────────────────────────────
// TRELLO
// ─────────────────────────────────────────────

model ConfigTrello {
  id          String   @id @default(cuid())
  apiKey      String
  token       String
  boardId     String
  ativo       Boolean  @default(true)
  listMapping Json?    // { "trello_list_id": "entrada", ... }
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("config_trello")
}

// ─────────────────────────────────────────────
// PERMISSÕES CONFIGURÁVEIS POR USUÁRIO
// ─────────────────────────────────────────────

model PermissaoUsuario {
  id        String   @id @default(cuid())
  usuarioId String   @unique

  // Páginas visíveis (checklist)
  verDashboard    Boolean @default(true)
  verDemandas     Boolean @default(true)
  verAprovacoes   Boolean @default(false)
  verAgenda       Boolean @default(false)
  verProdutos     Boolean @default(false)
  verVideomakers  Boolean @default(false)
  verEquipe       Boolean @default(false)
  verCustos       Boolean @default(false)
  verIA           Boolean @default(false)
  verAlertas      Boolean @default(false)
  verRelatorios   Boolean @default(false)
  verUsuarios     Boolean @default(false)
  verConfiguracoes Boolean @default(false)
  verIdeias        Boolean @default(false)
  verEventos       Boolean @default(false)
  verCoberturas        Boolean @default(false)
  verFinanceiroEvento  Boolean @default(false)
  gerenciarFornecedores Boolean @default(false)
  verDesign            Boolean @default(false)
  gerenciarDesigners   Boolean @default(false)

  // Ações em demandas
  criarDemanda    Boolean @default(false)
  editarDemanda   Boolean @default(false)
  excluirDemanda  Boolean @default(false)
  moverKanban     Boolean @default(false)

  // Visão de demandas
  verTodasDemandas Boolean @default(false) // false = só as próprias
  verKanban        Boolean @default(true)  // false = visualização em cards

  // Admin
  gerenciarUsuarios Boolean @default(false)
  gerenciarConfig   Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  usuario Usuario @relation(fields: [usuarioId], references: [id], onDelete: Cascade)

  @@map("permissoes_usuario")
}

// ─────────────────────────────────────────────
// CONVITE DE VIDEOMAKER (atribuição a demanda)
// ─────────────────────────────────────────────

model ConviteVideomaker {
  id           String    @id @default(cuid())
  demandaId    String
  videomakerId String
  token        String    @unique @default(cuid())
  status       String    @default("pendente") // pendente | aceito | recusado | expirado
  respondidoEm DateTime?
  expiresAt    DateTime
  createdAt    DateTime  @default(now())

  demanda    Demanda    @relation(fields: [demandaId], references: [id], onDelete: Cascade)
  videomaker Videomaker @relation(fields: [videomakerId], references: [id])

  @@map("convites_videomaker")
}

// ─────────────────────────────────────────────
// NOTA FISCAL UPLOAD (link público)
// ─────────────────────────────────────────────

model NotaFiscalUpload {
  id           String   @id @default(cuid())
  demandaId    String
  videomakerId String
  token        String   @unique @default(cuid())
  url          String?        // Supabase Storage URL após upload
  nomeArquivo  String?
  status       String   @default("pendente") // pendente | enviada | aprovada | rejeitada
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  demanda    Demanda    @relation(fields: [demandaId], references: [id], onDelete: Cascade)
  videomaker Videomaker @relation(fields: [videomakerId], references: [id])

  @@map("notas_fiscais")
}

// ─────────────────────────────────────────────
// DADOS DA EMPRESA (para NF de videomakers)
// ─────────────────────────────────────────────

model ConfigEmpresa {
  organizacaoId String?
  id            String   @id @default(cuid())
  cnpj          String?
  razaoSocial   String?
  nomeFantasia  String?
  endereco      String?
  bairro        String?
  cidade        String?
  estado        String?
  cep           String?
  email         String?
  telefone      String?
  pixKey        String?   // CNPJ, email, celular ou chave aleatória
  pixTipo       String?   // "cnpj" | "email" | "telefone" | "aleatoria"
  observacoesNF String?   // instrução para videomakers ao emitir NF

  // Google Drive — OAuth2 (refresh token da conta pessoal do usuário)
  googleRefreshToken     String?
  googleDriveEmail       String?
  googleDriveConnectedAt DateTime?
  googleDriveFolderId    String?   // ID da pasta onde os vídeos são salvos

  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@map("config_empresa")
}

model Depoimento {
  id           String   @id @default(cuid())
  nome         String
  cidade       String?
  videoUrl     String
  thumbnailUrl String?
  descricao    String?  @db.Text
  ativo        Boolean  @default(true)
  ordem        Int      @default(0)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@map("depoimentos")
}

// ─────────────────────────────────────────────
// EVENTOS & COBERTURAS
// ─────────────────────────────────────────────

enum TipoCobertura {
  congresso
  feira
  evento_corporativo
  show
  lancamento
  outro
}

enum StatusCobertura {
  planejamento
  em_andamento
  concluido
  cancelado
}

enum FuncaoEquipe {
  captacao
  edicao
  fotografia
  drone
  suporte
  social_media
}

enum CategoriaChecklist {
  equipamento
  logistica
  conteudo
  entrega
}

enum TipoMomento {
  abertura
  palestra
  workshop
  coquetel
  exposicao
  bastidores
  encerramento
  outro
}

model EventoCobertura {
  organizacaoId String?
  id                  String          @id @default(cuid())
  titulo              String
  slug                String          @unique
  tipo                TipoCobertura   @default(outro)
  status              StatusCobertura @default(planejamento)
  descricao           String?         @db.Text
  cliente             String?
  local               String?
  cidade              String?
  dataInicio          DateTime
  dataFim             DateTime
  totalDias           Int             @default(1)
  diasAtivos          Int             @default(0)
  linkDrive           String?
  linkDownloadPublico Boolean         @default(false)
  senhaDownload       String?
  produtoId           String?
  createdById         String
  createdAt           DateTime        @default(now())
  updatedAt           DateTime        @updatedAt

  produto    Produto?                   @relation(fields: [produtoId], references: [id])
  createdBy  Usuario                    @relation("CoberturasCreadas", fields: [createdById], references: [id])
  equipe     EventoCoberturaEquipe[]
  checklist  EventoCoberturaChecklist[]
  uploads    EventoCoberturaUpload[]
  album      EventoCoberturaAlbum[]
  log        EventoCoberturaLog[]
  demandas   Demanda[]
  eventoGestao EventoGestao?

  @@map("coberturas")
}

model EventoCoberturaEquipe {
  id               String       @id @default(cuid())
  coberturaId      String
  videomakerId     String?
  editorId         String?
  usuarioId        String?
  nome             String
  funcao           FuncaoEquipe @default(captacao)
  diariasTotal     Int          @default(0)
  diariasEfetuadas Int          @default(0)
  valorDiaria      Float?
  createdAt        DateTime     @default(now())

  cobertura  EventoCobertura       @relation(fields: [coberturaId], references: [id], onDelete: Cascade)
  videomaker Videomaker?           @relation(fields: [videomakerId], references: [id])
  editor     Editor?               @relation(fields: [editorId], references: [id])
  usuario    Usuario?              @relation(fields: [usuarioId], references: [id])
  uploads    EventoCoberturaUpload[]

  @@map("coberturas_equipe")
}

model EventoCoberturaChecklist {
  id           String             @id @default(cuid())
  coberturaId  String
  dia          Int
  texto        String
  categoria    CategoriaChecklist @default(equipamento)
  concluido    Boolean            @default(false)
  concluidoEm  DateTime?
  concluidoPor String?
  createdAt    DateTime           @default(now())

  cobertura EventoCobertura @relation(fields: [coberturaId], references: [id], onDelete: Cascade)

  @@map("coberturas_checklist")
}

model EventoCoberturaUpload {
  id           String      @id @default(cuid())
  coberturaId  String
  membroId     String?
  dia          Int
  tipo         String      @default("video")
  momento      TipoMomento @default(outro)
  titulo       String?
  url          String
  thumbnailUrl String?
  duracao      Int?
  tamanhoBytes BigInt?
  driveUrl     String?
  createdAt    DateTime    @default(now())

  cobertura       EventoCobertura        @relation(fields: [coberturaId], references: [id], onDelete: Cascade)
  membro          EventoCoberturaEquipe? @relation(fields: [membroId], references: [id])
  faceDescriptors EventoFaceDescriptor[]

  @@map("coberturas_uploads")
}

model EventoFaceDescriptor {
  id         String   @id @default(cuid())
  uploadId   String
  descriptor Json     // Float32Array serializada como number[] (128 floats)
  createdAt  DateTime @default(now())

  upload EventoCoberturaUpload @relation(fields: [uploadId], references: [id], onDelete: Cascade)

  @@map("evento_face_descriptors")
}

model EventoCoberturaAlbum {
  id          String      @id @default(cuid())
  coberturaId String
  nome        String
  momento     TipoMomento @default(outro)
  dia         Int?
  fotos       String[]
  createdAt   DateTime    @default(now())

  cobertura EventoCobertura @relation(fields: [coberturaId], references: [id], onDelete: Cascade)

  @@map("coberturas_album")
}

model EventoCoberturaLog {
  id          String   @id @default(cuid())
  coberturaId String
  usuarioId   String?
  acao        String
  detalhe     String?  @db.Text
  createdAt   DateTime @default(now())

  cobertura EventoCobertura @relation(fields: [coberturaId], references: [id], onDelete: Cascade)

  @@map("coberturas_log")
}

// ═══════════════════════════════════════════════════════════════════════════
// NUFLOW EVENTOS — Módulo de Gestão de Eventos (guarda-chuva)
// ═══════════════════════════════════════════════════════════════════════════

enum TipoEventoGestao {
  cafe
  jantar
  webinar
  congresso
  feira
  ativacao
  unyque_experience
  treinamento
  lancamento
  evento_interno
  evento_medicos
  evento_fornecedores
  outro
}

enum StatusEventoGestao {
  ideia
  planejamento
  orcamento
  aprovacao
  producao
  execucao
  finalizado
  cancelado
}

enum StatusTarefa {
  pendente
  em_andamento
  aguardando_aprovacao
  concluido
  atrasado
  cancelado
}

enum PrioridadeTarefa {
  baixa
  media
  alta
  critica
}

enum CategoriaDocumento {
  manual_expositor
  programacao
  briefing
  contratos
  planta
  projeto_stand
  layout_identidade
  material_impresso
  artes_digitais
  audiovisual
  outros
}

enum StatusDocumento {
  pendente
  enviado
  em_analise
  aprovado
  reprovado
  finalizado
}

enum CategoriaFornecedor {
  montadora
  grafica
  audiovisual
  som
  iluminacao
  buffet
  restaurante
  hotel
  transporte
  brindes
  decoracao
  agencia
  designer
  fotografo
  videomaker
  seguranca
  limpeza
  internet
  energia
  palestrante
  medico
  influenciador
  espaco
  painel_led
  outros
}

enum UnidadeMedida {
  unidade
  metro_quadrado
  diaria
  hora
  pacote
  pessoa
  evento_fechado
  lote
  impressao
  servico
}

enum CategoriaCusto {
  stand
  montagem
  comunicacao_visual
  audiovisual
  buffet
  jantar
  brindes
  impressos
  trafego
  hospedagem
  transporte
  palestrantes
  medicos
  equipe
  taxas
  extras
}

enum TipoAprovacao {
  orcamento
  layout
  material
  contrato
  entrega
}

model EventoGestao {
  organizacaoId String?
  id                 String             @id @default(cuid())
  codigo             String             @unique
  nome               String
  tipo               TipoEventoGestao   @default(outro)
  status             StatusEventoGestao @default(planejamento)
  descricao          String?            @db.Text
  objetivo           String?            @db.Text
  publicoAlvo        String?
  observacoes        String?            @db.Text
  cidade             String?
  estado             String?
  local              String?
  dataInicio         DateTime
  dataFim            DateTime
  responsavelId      String?
  orcamentoPrevisto  Float?
  orcamentoAprovado  Float?
  percentualConclusao Int               @default(0)
  linkDrive          String?
  coberturaId        String?            @unique
  createdById        String
  createdAt          DateTime           @default(now())
  updatedAt          DateTime           @updatedAt

  responsavel  Usuario?         @relation("EventoGestaoResponsavel", fields: [responsavelId], references: [id])
  createdBy    Usuario          @relation("EventoGestaoCriador", fields: [createdById], references: [id])
  cobertura    EventoCobertura? @relation(fields: [coberturaId], references: [id])
  demandas     Demanda[]
  checklist    EventoGestaoChecklist[]
  documentos   EventoGestaoDocumento[]
  custos       CustoEvento[]
  aprovacoes   EventoGestaoAprovacao[]
  logs         EventoGestaoLog[]

  @@map("eventos_gestao")
}

model EventoGestaoChecklist {
  id               String           @id @default(cuid())
  eventoId         String
  titulo           String
  descricao        String?
  categoria        String?
  responsavelId    String?
  prazo            DateTime?
  status           StatusTarefa     @default(pendente)
  prioridade       PrioridadeTarefa @default(media)
  uploadObrigatorio Boolean         @default(false)
  custoEventoId    String?
  concluido        Boolean          @default(false)
  concluidoEm      DateTime?
  createdAt        DateTime         @default(now())

  evento      EventoGestao @relation(fields: [eventoId], references: [id], onDelete: Cascade)
  responsavel Usuario?     @relation(fields: [responsavelId], references: [id])

  @@map("eventos_gestao_checklist")
}

model EventoGestaoDocumento {
  id            String             @id @default(cuid())
  eventoId      String
  categoria     CategoriaDocumento @default(outros)
  nome          String
  url           String?
  linkExterno   String?
  responsavelId String?
  prazo         DateTime?
  status        StatusDocumento    @default(pendente)
  observacoes   String?
  createdAt     DateTime           @default(now())
  updatedAt     DateTime           @updatedAt

  evento      EventoGestao @relation(fields: [eventoId], references: [id], onDelete: Cascade)
  responsavel Usuario?     @relation(fields: [responsavelId], references: [id])

  @@map("eventos_gestao_documentos")
}

model Fornecedor {
  organizacaoId String?
  id             String              @id @default(cuid())
  nome           String
  contato        String?
  cnpj           String?
  telefone       String?
  email          String?
  cidade         String?
  estado         String?
  categoria      CategoriaFornecedor @default(outros)
  dadosBancarios String?
  pixKey         String?
  observacoes    String?             @db.Text
  avaliacao      Float?              @default(5.0)
  status         StatusUsuario       @default(ativo)
  portalToken    String              @unique @default(cuid())
  createdAt      DateTime            @default(now())
  updatedAt      DateTime            @updatedAt

  produtos ProdutoServicoEvento[]
  custos   CustoEvento[]

  @@map("fornecedores")
}

model ProdutoServicoEvento {
  id               String        @id @default(cuid())
  nome             String
  categoria        String?
  fornecedorId     String?
  valorUnitario    Float?
  unidadeMedida    UnidadeMedida @default(unidade)
  quantidadeMinima Int?
  prazoMedioDias   Int?
  imagemUrl        String?
  observacoes      String?
  ativo            Boolean       @default(true)
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt

  fornecedor Fornecedor?   @relation(fields: [fornecedorId], references: [id])
  custos     CustoEvento[]

  @@map("produtos_servico_evento")
}

model CustoEvento {
  id               String          @id @default(cuid())
  eventoId         String
  fornecedorId     String?
  produtoServicoId String?
  categoria        CategoriaCusto  @default(extras)
  descricao        String
  valorPrevisto    Float           @default(0)
  valorReal        Float?
  quantidade       Float?
  pago             Boolean         @default(false)
  dataPagamento    DateTime?
  notaFiscalUrl    String?
  statusPagamento  StatusPagamento @default(pendente_nf)
  dataVencimento   DateTime?
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt

  evento         EventoGestao          @relation(fields: [eventoId], references: [id], onDelete: Cascade)
  fornecedor     Fornecedor?           @relation(fields: [fornecedorId], references: [id])
  produtoServico ProdutoServicoEvento? @relation(fields: [produtoServicoId], references: [id])

  @@map("custos_evento")
}

model EventoGestaoAprovacao {
  id         String        @id @default(cuid())
  eventoId   String
  tipo       TipoAprovacao
  status     String        @default("pendente") // pendente | aprovado | reprovado
  aprovadoPor String?
  observacao String?
  createdAt  DateTime      @default(now())
  updatedAt  DateTime      @updatedAt

  evento EventoGestao @relation(fields: [eventoId], references: [id], onDelete: Cascade)

  @@map("eventos_gestao_aprovacoes")
}

model EventoGestaoLog {
  id        String   @id @default(cuid())
  eventoId  String
  usuarioId String?
  acao      String
  detalhe   String?  @db.Text
  createdAt DateTime @default(now())

  evento EventoGestao @relation(fields: [eventoId], references: [id], onDelete: Cascade)

  @@map("eventos_gestao_log")
}

// Produção lançada manualmente (vídeos feitos que não viraram card no NuFlow)
// Por competência (ano*100+mes), área e categoria (ex: "Linha Med", "Linha Estética").
model ProducaoManual {
  organizacaoId String?
  id          String   @id @default(cuid())
  competencia Int      // ano*100 + mes (ex: 202606)
  area        String   @default("audiovisual")
  grupo       String   @default("producao")  // "producao" (vídeos) | "presencial" (frentes)
  categoria   String
  quantidade  Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([competencia, area, grupo, categoria])
  @@map("producao_manual")
}

// ─── SaaS multiempresa ────────────────────────────────────────────────────────
model Organizacao {
  id        String   @id @default(cuid())
  nome      String
  slug      String   @unique  // ex: "contourline" (preparado p/ subdomínio futuro)
  logoUrl   String?
  ativo     Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  membros UsuarioOrganizacao[]
  configEmailEntrada ConfigEmailEntrada?
  emailsEntrada      EmailEntrada[]
  linhasProjeto      LinhaProjeto[]

  @@map("organizacoes")
}

// Linha/Projeto (segmentação do Growth) — por organização. Substitui o texto livre.
// Nomes iguais podem coexistir entre empresas (unique por org, nunca global).
model LinhaProjeto {
  id            String   @id @default(cuid())
  organizacaoId String
  nome          String
  descricao     String?
  ativo         Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  organizacao Organizacao @relation(fields: [organizacaoId], references: [id], onDelete: Cascade)
  demandas    Demanda[]

  @@unique([organizacaoId, nome])
  @@index([organizacaoId])
  @@map("linhas_projeto")
}

model UsuarioOrganizacao {
  id            String      @id @default(cuid())
  usuarioId     String
  organizacaoId String
  papel         TipoUsuario @default(solicitante)
  createdAt     DateTime    @default(now())

  usuario     Usuario     @relation(fields: [usuarioId], references: [id], onDelete: Cascade)
  organizacao Organizacao @relation(fields: [organizacaoId], references: [id], onDelete: Cascade)

  @@unique([usuarioId, organizacaoId])
  @@index([organizacaoId])
  @@map("usuario_organizacao")
}
