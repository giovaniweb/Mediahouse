generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["driverAdapters"]
}

datasource db {
  provider = "postgresql"
}

// ─────────────────────────────────────────────
// ENUMS
// ─────────────────────────────────────────────

enum TipoUsuario {
  admin
  gestor
  operacao
  solicitante
  editor
  videomaker
  social
}

enum StatusUsuario {
  ativo
  inativo
}

enum StatusVideomaker {
  ativo
  inativo
  preferencial
  pendente
}

enum Prioridade {
  normal
  alta
  urgente
}

enum Departamento {
  growth
  eventos
  institucional
  rh
  audiovisual
  outros
}

enum StatusVisivel {
  entrada
  producao
  edicao
  aprovacao
  para_postar
  finalizado
}

enum StatusInterno {
  pedido_criado
  aguardando_aprovacao_interna
  aguardando_triagem
  urgencia_pendente_aprovacao
  urgencia_aprovada
  planejamento
  videomaker_notificado
  videomaker_aceitou
  videomaker_recusou
  captacao_agendada
  captacao_realizada
  brutos_enviados
  editor_atribuido
  fila_edicao
  editando
  edicao_finalizada
  revisao_pendente
  aprovado
  ajuste_solicitado
  impedimento
  postagem_pendente
  postado
  entregue_cliente
  contagem_15_dias_iniciada
  lembrete_15_dias_enviado
  expirado
  encerrado
}

enum OrigemHistorico {
  manual
  automacao
  ia
  whatsapp
  kanban
}

enum TipoArquivo {
  bruto
  final
  nota_fiscal
  referencia
  postagem
  cliente
}

enum DirecaoWhatsapp {
  entrada
  saida
}

enum StatusAlerta {
  ativo
  resolvido
  ignorado
}

enum SeveridadeAlerta {
  info
  aviso
  critico
}

enum StatusIdeia {
  nova
  em_analise
  aprovada
  em_producao
  realizada
  descartada
}

enum OrigemIdeia {
  whatsapp
  manual
  instagram
  tiktok
  youtube
  outro
}

// ─────────────────────────────────────────────
// MODELS
// ─────────────────────────────────────────────

model Usuario {
  id        String        @id @default(cuid())
  nome      String
  email     String        @unique
  telefone  String?
  tipo      TipoUsuario   @default(solicitante)
  status    StatusUsuario @default(ativo)
  senhaHash String
  avatarUrl String?
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt

  demandasCriadas Demanda[]         @relation("Solicitante")
  demandasGeridas Demanda[]         @relation("Gestor")
  historicos      HistoricoStatus[]
  comentarios     Comentario[]
  sessions        Session[]
  eventos         Evento[]
  permissoes      PermissaoUsuario?
  videomakerRef   Videomaker?       // link para videomaker externo (quando tipo=videomaker)
  ideias          IdeiaVideo[]

  @@map("usuarios")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         Usuario  @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model Videomaker {
  id               String           @id @default(cuid())
  nome             String
  cidade           String?
  estado           String?
  telefone         String?
  email            String?
  cpfCnpj          String?
  razaoSocial      String?
  nomeFantasia     String?
  representante    String?
  endereco         String?
  chavePix         String?
  redesSociais     String[]
  valorDiaria      Float?
  dadosBancarios   String?
  status           StatusVideomaker @default(ativo)
  avaliacao        Float?           @default(5.0)
  observacoes      String?
  areasAtuacao     String[]
  habilidades      String[]         // tags: "Edição", "3D", "Drone" etc.
  equipamentos     String[]         // câmeras, lentes, drones, iluminação etc.
  portfolio        String?
  emListaNegra     Boolean          @default(false)
  listaNegraMotivo String?
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt

  usuarioId  String?    @unique  // link para Usuario (portal login)
  usuario    Usuario?   @relation(fields: [usuarioId], references: [id])

  demandas       Demanda[]
  eventos        Evento[]
  custos         CustoVideomaker[]
  avaliacoes     AvaliacaoVideomaker[]
  convites       ConviteVideomaker[]
  notasFiscais   NotaFiscalUpload[]

  @@map("videomakers")
}

model Editor {
  id            String        @id @default(cuid())
  nome          String
  telefone      String?
  whatsapp      String?       // número WhatsApp (pode ser igual ao telefone)
  email         String?
  avatarUrl     String?       // foto de perfil
  especialidade String[]
  habilidades   String[]      // tags abertas de habilidades
  cargaLimite   Int           @default(5)
  status        StatusUsuario @default(ativo)
  avaliacao        Float?        @default(5.0)
  cidade           String?
  estado           String?
  cpfCnpj          String?
  razaoSocial      String?
  nomeFantasia     String?
  representante    String?
  endereco         String?
  chavePix         String?
  redesSociais     String[]
  salario          Float?           // ONLY visible to admin/gestor
  dadosBancarios   String?
  observacoes      String?
  areasAtuacao     String[]
  equipamentos     String[]
  portfolio        String?
  emListaNegra     Boolean          @default(false)
  listaNegraMotivo String?
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt

  demandas   Demanda[]
  avaliacoes AvaliacaoEditor[]
  eventos    Evento[]

  @@map("editores")
}

model Demanda {
  id             String        @id @default(cuid())
  codigo         String        @unique
  titulo         String
  descricao      String
  departamento   Departamento
  tipoVideo      String
  cidade         String
  prioridade     Prioridade    @default(normal)
  motivoUrgencia String?
  statusVisivel  StatusVisivel @default(entrada)
  statusInterno  StatusInterno @default(pedido_criado)
  pesoDemanda    Float         @default(1)
  riscoAtraso    Boolean       @default(false)

  classificacao     String?    // "b2c" | "b2b" — classification of the video

  // Dados extras por departamento
  campanha          String?
  objetivo          String?
  plataforma        String?
  dataEvento        DateTime?
  localEvento       String?
  cobertura         Boolean?
  publico           String?
  mensagemPrincipal String?

  // Links operacionais
  linkBrutos      String?
  linkFinal       String?
  linkPostagem    String?
  linkCliente     String?
  localGravacao   String?
  referencia      String?

  // Impedimento
  motivoImpedimento String?

  // Telefone do solicitante (capturado via WhatsApp para follow-up)
  telefoneSolicitante String?

  // Cliente final (cobertura/entrega de equipamento)
  clienteFinalNome     String?
  clienteFinalTelefone String?
  clienteFinalEmail    String?

  // Nota fiscal
  notaFiscalUrl  String?
  notaFiscalNome String?

  trelloCardId      String?  @unique  // Trello card ID to prevent re-import

  // Relações de usuários (FKs)
  solicitanteId String
  gestorId      String?
  videomakerId  String?
  editorId      String?
  socialId      String?

  // Datas
  dataLimite         DateTime?
  dataCaptacao       DateTime?
  dataPostagem       DateTime?
  dataEntregaCliente DateTime?
  dataExpiracao      DateTime?
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  // Relações
  solicitante        Usuario            @relation("Solicitante", fields: [solicitanteId], references: [id])
  gestor             Usuario?           @relation("Gestor", fields: [gestorId], references: [id])
  videomaker         Videomaker?        @relation(fields: [videomakerId], references: [id])
  editor             Editor?            @relation(fields: [editorId], references: [id])
  arquivos           Arquivo[]
  historicos         HistoricoStatus[]
  comentarios        Comentario[]
  alertas            AlertaIA[]
  aprovacoesVideo    AprovacaoVideo[]
  mensagensWhatsapp  MensagemWhatsapp[]
  logsAutomacao      LogAutomacao[]
  eventos            Evento[]
  custos             CustoVideomaker[]
  produtos           DemandaProduto[]
  checklistItens     ChecklistItem[]
  convites           ConviteVideomaker[]
  notasFiscais       NotaFiscalUpload[]
  ideia              IdeiaVideo?

  @@map("demandas")
}

// ── Checklist System (estilo Trello) ──────────────────────────────────────────

model ChecklistTemplate {
  id        String                  @id @default(cuid())
  nome      String                  // "Entrega Equipamento - VM Externo"
  tipoVideo String?                 // match automático ao criar demanda
  papel     String?                 // "videomaker_externo" | "editor" | "social" | "geral"
  ativo     Boolean                 @default(true)
  itens     ChecklistTemplateItem[]
  createdAt DateTime                @default(now())
  updatedAt DateTime                @updatedAt

  @@map("checklist_templates")
}

model ChecklistTemplateItem {
  id         String            @id @default(cuid())
  templateId String
  texto      String
  ordem      Int               @default(0)
  template   ChecklistTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)

  @@map("checklist_template_itens")
}

model ChecklistItem {
  id           String    @id @default(cuid())
  demandaId    String
  texto        String
  concluido    Boolean   @default(false)
  concluidoEm  DateTime?
  concluidoPor String?
  ordem        Int       @default(0)
  grupo        String?   // "videomaker_externo", "editor", "social", "geral"
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  demanda Demanda @relation(fields: [demandaId], references: [id], onDelete: Cascade)

  @@map("checklist_itens")
}

model Arquivo {
  id          String      @id @default(cuid())
  demandaId   String
  tipoArquivo TipoArquivo
  nomeArquivo String
  url         String
  tamanho     Int?
  origem      String?
  createdAt   DateTime    @default(now())

  demanda Demanda @relation(fields: [demandaId], references: [id], onDelete: Cascade)

  @@map("arquivos")
}

model HistoricoStatus {
  id             String          @id @default(cuid())
  demandaId      String
  statusAnterior String?
  statusNovo     String
  usuarioId      String?
  origem         OrigemHistorico @default(manual)
  observacao     String?
  createdAt      DateTime        @default(now())

  demanda Demanda  @relation(fields: [demandaId], references: [id], onDelete: Cascade)
  usuario Usuario? @relation(fields: [usuarioId], references: [id])

  @@map("historico_status")
}

model Comentario {
  id         String   @id @default(cuid())
  demandaId  String
  usuarioId  String
  comentario String
  origem     String   @default("manual")
  createdAt  DateTime @default(now())

  demanda Demanda @relation(fields: [demandaId], references: [id], onDelete: Cascade)
  usuario Usuario @relation(fields: [usuarioId], references: [id])

  @@map("comentarios")
}

model AlertaIA {
  id           String           @id @default(cuid())
  demandaId    String?
  usuarioId    String?
  tipoAlerta   String
  mensagem     String
  severidade   SeveridadeAlerta @default(aviso)
  status       StatusAlerta     @default(ativo)
  lida         Boolean          @default(false)
  acaoSugerida String?
  createdAt    DateTime         @default(now())
  resolvedAt   DateTime?

  demanda Demanda? @relation(fields: [demandaId], references: [id], onDelete: Cascade)

  @@map("alertas_ia")
}

model AprovacaoVideo {
  id           String   @id @default(cuid())
  demandaId    String
  token        String   @unique @default(cuid())
  nomeVideo    String?
  urlVideo     String
  status       String   @default("pendente")
  aprovadoPor  String?
  comentario   String?
  expiresAt    DateTime?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  demanda Demanda @relation(fields: [demandaId], references: [id], onDelete: Cascade)

  @@map("aprovacoes_video")
}

model ConfigWhatsapp {
  id          String   @id @default(cuid())
  instanceUrl String
  apiKey      String
  instanceId  String
  ativo       Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("config_whatsapp")
}

model MensagemWhatsapp {
  id           String          @id @default(cuid())
  demandaId    String?
  telefone     String
  tipoMensagem String          // "text" | "image" | "video" | "audio" | "document"
  conteudo     String
  mediaUrl     String?         // URL do arquivo no Supabase Storage (se mídia)
  mediaType    String?         // MIME type (ex: "image/jpeg", "audio/ogg")
  direcao      DirecaoWhatsapp @default(saida)
  status       String          @default("enviado")
  createdAt    DateTime        @default(now())

  demanda Demanda? @relation(fields: [demandaId], references: [id])

  @@map("mensagens_whatsapp")
}

model LogAutomacao {
  id         String   @id @default(cuid())
  demandaId  String?
  automacao  String
  inputJson  Json?
  outputJson Json?
  status     String   @default("sucesso")
  createdAt  DateTime @default(now())

  demanda Demanda? @relation(fields: [demandaId], references: [id])

  @@map("logs_automacao")
}

// ─────────────────────────────────────────────
// AGENDA
// ─────────────────────────────────────────────

enum TipoEvento {
  captacao
  edicao
  reuniao
  freelance
  pessoal
  empresa
  prazo
  outro
}

enum ContextoEvento {
  contourline  // prioridade máxima — empresa principal
  freelance    // serviços externos
  pessoal      // agenda particular do admin
  sistema      // gerado automaticamente por demanda
}

enum StatusEvento {
  agendado
  confirmado
  em_andamento
  concluido
  cancelado
}

model Evento {
  id           String         @id @default(cuid())
  titulo       String
  descricao    String?
  inicio       DateTime
  fim          DateTime
  diaTodo      Boolean        @default(false)
  tipo         TipoEvento     @default(outro)
  contexto     ContextoEvento @default(sistema)
  status       StatusEvento   @default(agendado)
  cor          String?        // hex, ex: #ef4444
  local        String?
  privado      Boolean        @default(false)

  // Relações opcionais
  demandaId    String?
  usuarioId    String?        // admin/gestor
  videomakerId String?        // agenda do videomaker externo
  editorId     String?        // agenda do videomaker interno (editor)

  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt

  demanda    Demanda?    @relation(fields: [demandaId], references: [id], onDelete: Cascade)
  usuario    Usuario?    @relation(fields: [usuarioId], references: [id])
  videomaker Videomaker? @relation(fields: [videomakerId], references: [id])
  editor     Editor?     @relation(fields: [editorId], references: [id])

  @@map("eventos")
}

// ─────────────────────────────────────────────
// CUSTOS
// ─────────────────────────────────────────────

enum TipoCusto {
  diaria
  mensalidade
  projeto
  bonus
  despesa
  equipamento
}

enum StatusPagamento {
  pendente_nf          // aguardando videomaker enviar nota fiscal
  nf_enviada           // NF recebida, aguardando aprovação interna
  aguardando_pagamento // aprovado → e-mail enviado ao financeiro
  pago                 // confirmado pago
  contestado           // em disputa
}

model CustoVideomaker {
  id                String          @id @default(cuid())
  videomakerId      String
  demandaId         String?
  tipo              TipoCusto       @default(diaria)
  valor             Float
  descricao         String?
  dataReferencia    DateTime
  pago              Boolean         @default(false)
  dataPagamento     DateTime?
  comprovante       String?
  notaFiscalUrl     String?         // URL da NF enviada pelo videomaker
  statusPagamento   StatusPagamento @default(pendente_nf)
  emailFinanceiroAt DateTime?       // quando o e-mail foi enviado ao financeiro
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt

  videomaker Videomaker @relation(fields: [videomakerId], references: [id])
  demanda    Demanda?   @relation(fields: [demandaId], references: [id])

  @@map("custos_videomaker")
}

// ─────────────────────────────────────────────
// RELATÓRIOS IA
// ─────────────────────────────────────────────

enum TipoRelatorio {
  produtividade_time
  analise_custos
  otimizacao_contratacao
  performance_videomaker
  semanal
  mensal
  realtime
  banco_ideias
}

model RelatorioIA {
  id         String        @id @default(cuid())
  tipo       TipoRelatorio
  periodo    String        // ex: "2025-W01", "2025-03", "realtime"
  conteudo   Json          // resposta estruturada da IA
  tokens     Int?          // tokens consumidos
  modelo     String        @default("claude-haiku-4-5")
  createdAt  DateTime      @default(now())

  @@map("relatorios_ia")
}

// ─────────────────────────────────────────────
// E-MAIL / FINANCEIRO
// ─────────────────────────────────────────────

model ConfigEmail {
  id               String   @id @default(cuid())
  apiKey           String   @default("") // Resend API Key
  senderEmail      String   @default("onboarding@resend.dev")
  senderNome       String   @default("VideoOps")
  emailsFinanceiro String[] // destinatários financeiro
  ativo            Boolean  @default(false)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@map("config_email")
}

// ─────────────────────────────────────────────
// AVALIAÇÕES DE VIDEOMAKER
// ─────────────────────────────────────────────

model AvaliacaoVideomaker {
  id           String     @id @default(cuid())
  videomakerId String
  nota         Int        // 1-5
  comentario   String?
  avaliadorId  String?    // null se via QR (avaliação pública)
  demandaId    String?
  origem       String     @default("interno") // "interno" | "qr_publico"
  createdAt    DateTime   @default(now())

  videomaker Videomaker @relation(fields: [videomakerId], references: [id], onDelete: Cascade)

  @@map("avaliacoes_videomaker")
}

// ─────────────────────────────────────────────
// AVALIAÇÕES DE EDITOR (Videomaker Int)
// ─────────────────────────────────────────────

model AvaliacaoEditor {
  id          String   @id @default(cuid())
  editorId    String
  nota        Int      // 1-5
  comentario  String?
  atendeuDemandas  Boolean?   // checklist: atendeu as demandas?
  foiAtencioso     Boolean?   // foi atencioso?
  contratariaNovamente Boolean? // contrataria novamente?
  avaliadorId String?          // null se via QR público
  demandaId   String?
  origem      String   @default("interno") // "interno" | "qr_publico"
  createdAt   DateTime @default(now())

  editor Editor @relation(fields: [editorId], references: [id], onDelete: Cascade)

  @@map("avaliacoes_editor")
}

// ─────────────────────────────────────────────
// PARÂMETROS DINÂMICOS (configurações editáveis)
// ─────────────────────────────────────────────

model ConfigParametro {
  id        String   @id @default(cuid())
  grupo     String   // "departamentos" | "tipos_video" | "habilidades" | "areas_atuacao"
  valor     String   // valor interno (ex: "growth")
  label     String   // label de exibição (ex: "Growth")
  ordem     Int      @default(0)
  ativo     Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([grupo, valor])
  @@map("config_parametros")
}

// ─────────────────────────────────────────────
// IA — CHAT E EXECUÇÃO DE AGENTES
// ─────────────────────────────────────────────

model ChatIAMensagem {
  id        String   @id @default(cuid())
  sessionId String   // identificador da sessão de chat (gerado no frontend)
  role      String   // "user" | "assistant"
  conteudo  String   @db.Text
  tokens    Int?
  createdAt DateTime @default(now())

  @@index([sessionId])
  @@map("chat_ia_mensagens")
}

model AgenteExecucao {
  id             String    @id @default(cuid())
  agente         String    // "triagem" | "monitor" | "gerar_alertas" | "custos" | "whatsapp"
  status         String    @default("executando") // "executando" | "concluido" | "erro"
  resultado      Json?
  tokens         Int?
  alertasGerados Int       @default(0)
  ferramentas    String[]  // ferramentas usadas
  erro           String?
  criadoPor      String?   // userId que acionou
  finishedAt     DateTime?
  createdAt      DateTime  @default(now())

  @@map("agente_execucoes")
}

// ─────────────────────────────────────────────
// RESET DE SENHA
// ─────────────────────────────────────────────

model PasswordResetToken {
  id        String    @id @default(cuid())
  email     String
  token     String    @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  @@map("password_reset_tokens")
}

// ─────────────────────────────────────────────
// PRODUTOS & CONTEÚDO
// ─────────────────────────────────────────────

model Fabricante {
  id        String    @id @default(cuid())
  nome      String    @unique
  ativo     Boolean   @default(true)
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  produtos  Produto[]

  @@map("fabricantes")
}

model Produto {
  id              String      @id @default(cuid())
  nome            String
  descricao       String?
  categoria       String?     // legacy — use fabricanteId
  fabricanteId    String?
  peso            Float       @default(1.0)    // 1-10 priority weight
  ativo           Boolean     @default(true)
  alertaDias      Int         @default(30)     // alert if no content in X days
  ultimoConteudo  DateTime?                  // denormalized: last content date
  totalConteudos  Int       @default(0)      // denormalized: total content count
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  fabricante      Fabricante?      @relation(fields: [fabricanteId], references: [id])
  demandas        DemandaProduto[]
  ideias          IdeiaVideo[]

  @@map("produtos")
}

model DemandaProduto {
  id         String   @id @default(cuid())
  demandaId  String
  produtoId  String
  createdAt  DateTime @default(now())

  demanda    Demanda  @relation(fields: [demandaId], references: [id], onDelete: Cascade)
  produto    Produto  @relation(fields: [produtoId], references: [id], onDelete: Cascade)

  @@unique([demandaId, produtoId])
  @@map("demanda_produto")
}

// ─────────────────────────────────────────────
// BANCO DE IDEIAS
// ─────────────────────────────────────────────

model IdeiaVideo {
  id              String       @id @default(cuid())
  titulo          String
  descricao       String?      @db.Text
  linkReferencia  String?
  mediaUrl        String?
  mediaType       String?
  origem          OrigemIdeia  @default(manual)
  plataforma      String?      // auto-detected: instagram, tiktok, youtube
  status          StatusIdeia  @default(nova)
  classificacao   String?      // b2c, b2b

  // IA Analysis
  scoreIA            Float?    // 0-100
  analiseIA          String?   @db.Text
  sugestaoTipo       String?
  sugestaoPrioridade String?
  analisadoEm        DateTime?

  // Quem enviou
  enviadoPor     String?
  telefoneOrigem String?
  usuarioId      String?

  // Produto
  produtoId String?

  // Conversão em demanda
  demandaId    String?   @unique
  convertidoEm DateTime?

  tags      String[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  usuario Usuario? @relation(fields: [usuarioId], references: [id])
  produto Produto? @relation(fields: [produtoId], references: [id])
  demanda Demanda? @relation(fields: [demandaId], references: [id])

  @@map("ideias_video")
}

// ─────────────────────────────────────────────
// TRELLO
// ─────────────────────────────────────────────

model ConfigTrello {
  id          String   @id @default(cuid())
  apiKey      String
  token       String
  boardId     String
  ativo       Boolean  @default(true)
  listMapping Json?    // { "trello_list_id": "entrada", ... }
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("config_trello")
}

// ─────────────────────────────────────────────
// PERMISSÕES CONFIGURÁVEIS POR USUÁRIO
// ─────────────────────────────────────────────

model PermissaoUsuario {
  id        String   @id @default(cuid())
  usuarioId String   @unique

  // Páginas visíveis (checklist)
  verDashboard    Boolean @default(true)
  verDemandas     Boolean @default(true)
  verAprovacoes   Boolean @default(false)
  verAgenda       Boolean @default(false)
  verProdutos     Boolean @default(false)
  verVideomakers  Boolean @default(false)
  verEquipe       Boolean @default(false)
  verCustos       Boolean @default(false)
  verIA           Boolean @default(false)
  verAlertas      Boolean @default(false)
  verRelatorios   Boolean @default(false)
  verUsuarios     Boolean @default(false)
  verConfiguracoes Boolean @default(false)
  verIdeias        Boolean @default(false)

  // Ações em demandas
  criarDemanda    Boolean @default(false)
  editarDemanda   Boolean @default(false)
  excluirDemanda  Boolean @default(false)
  moverKanban     Boolean @default(false)

  // Visão de demandas
  verTodasDemandas Boolean @default(false) // false = só as próprias
  verKanban        Boolean @default(true)  // false = visualização em cards

  // Admin
  gerenciarUsuarios Boolean @default(false)
  gerenciarConfig   Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  usuario Usuario @relation(fields: [usuarioId], references: [id], onDelete: Cascade)

  @@map("permissoes_usuario")
}

// ─────────────────────────────────────────────
// CONVITE DE VIDEOMAKER (atribuição a demanda)
// ─────────────────────────────────────────────

model ConviteVideomaker {
  id           String    @id @default(cuid())
  demandaId    String
  videomakerId String
  token        String    @unique @default(cuid())
  status       String    @default("pendente") // pendente | aceito | recusado | expirado
  respondidoEm DateTime?
  expiresAt    DateTime
  createdAt    DateTime  @default(now())

  demanda    Demanda    @relation(fields: [demandaId], references: [id], onDelete: Cascade)
  videomaker Videomaker @relation(fields: [videomakerId], references: [id])

  @@map("convites_videomaker")
}

// ─────────────────────────────────────────────
// NOTA FISCAL UPLOAD (link público)
// ─────────────────────────────────────────────

model NotaFiscalUpload {
  id           String   @id @default(cuid())
  demandaId    String
  videomakerId String
  token        String   @unique @default(cuid())
  url          String?        // Supabase Storage URL após upload
  nomeArquivo  String?
  status       String   @default("pendente") // pendente | enviada | aprovada | rejeitada
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  demanda    Demanda    @relation(fields: [demandaId], references: [id], onDelete: Cascade)
  videomaker Videomaker @relation(fields: [videomakerId], references: [id])

  @@map("notas_fiscais")
}
